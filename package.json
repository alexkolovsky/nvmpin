{
  "name": "nvmpin",
  "version": "0.1.0",
  "description": "Pin global npm packages to specific nvm node versions via shims — global CLIs keep working across nvm version switches.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexkolovsky/nvmpin.git"
  },
  "bugs": {
    "url": "https://github.com/alexkolovsky/nvmpin/issues"
  },
  "homepage": "https://github.com/alexkolovsky/nvmpin#readme",
  "type": "module",
  "bin": {
    "nvmpin": "src/cli.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test 'test/*.test.js'",
    "test:integration": "NVMPIN_INTEGRATION=1 node --test 'test/*.test.js'",
    "prepublishOnly": "npm run test && npm run test:integration"
  },
  "keywords": [
    "nvm",
    "node-version",
    "global-packages",
    "shim",
    "cli",
    "version-manager",
    "pin",
    "node"
  ],
  "author": "Alex Kolovskiy",
  "license": "MIT"
}
